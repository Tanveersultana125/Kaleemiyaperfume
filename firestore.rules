rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }
    
    function isWhitelistedSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email.toLower() == 'kaleemiya.perfumes@gmail.com' || 
        request.auth.token.email.toLower() == 'tanveersultna84@gmail.com' ||
        request.auth.token.email.toLower() == 'tanveersultana84@gmail.com'
      );
    }
    
    function isSuperAdmin() {
      return isWhitelistedSuperAdmin() || hasRole('super_admin');
    }
    
    function isAdmin() {
      return isWhitelistedSuperAdmin() || hasRole('admin') || hasRole('super_admin');
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Only Super Admin can update roles
      allow update: if isSuperAdmin() || (request.auth.uid == userId && request.resource.data.role == resource.data.role);
      // Safeguard: Never delete a super admin or anyone on the whitelist
      allow delete: if isSuperAdmin() && 
                    resource.data.role != 'super_admin' && 
                    resource.data.email.toLower() != 'kaleemiya.perfumes@gmail.com' &&
                    resource.data.email.toLower() != 'tanveersultna84@gmail.com' &&
                    resource.data.email.toLower() != 'tanveersultana84@gmail.com';
    }

    // Admin Requests Collection
    match /adminRequests/{requestId} {
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid && request.resource.data.status == 'pending';
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Products (Inventory) Collection
    match /products/{productId} {
      allow read: if true; // Everyone can see products
      allow write: if isAdmin();
    }
    
    // Metadata (Categories)
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // News Desk Collection
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
